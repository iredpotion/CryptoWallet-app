{
	"info": {
		"_postman_id": "crypto-wallet-v1-day3",
		"name": "Crypto Wallet API (Completo)",
		"description": "Collection final contendo todos os requisitos do teste prático: Auth, Depósito, Swap, Saque e Extrato Paginado.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Auth",
			"item": [
				{
					"name": "Registrar Usuário",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"investor@nexus.com\",\n    \"password\": \"senha123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"register"
							]
						}
					}
				},
				{
					"name": "Login (Auto-Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access_token) {",
									"    pm.collectionVariables.set(\"token\", jsonData.access_token);",
									"    console.log(\"Token salvo: \" + jsonData.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"investor@nexus.com\",\n    \"password\": \"senha123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"login"
							]
						}
					}
				}
			]
		},
		{
			"name": "2. Carteira & Depósito",
			"item": [
				{
					"name": "Minha Carteira",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.userId) {",
									"    pm.collectionVariables.set(\"userId\", jsonData.userId);",
									"} else if (jsonData.user && jsonData.user.id) {",
									"    pm.collectionVariables.set(\"userId\", jsonData.user.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/wallet",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"wallet"
							]
						}
					}
				},
				{
					"name": "Depositar (Webhook Exerno)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"userId\": \"{{userId}}\",\n    \"token\": \"BRL\",\n    \"amount\": 10000,\n    \"idempotencyKey\": \"{{$guid}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/webhooks/deposit",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"webhooks",
								"deposit"
							]
						},
						"description": "Requisito 3: Simula entrada de dinheiro na carteira"
					}
				}
			]
		},
		{
			"name": "3. Conversão (Swap)",
			"item": [
				{
					"name": "Cotar BRL -> BTC",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/wallet/swap/quote?from=BRL&to=BTC&amount=5000",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"wallet",
								"swap",
								"quote"
							],
							"query": [
								{
									"key": "from",
									"value": "BRL"
								},
								{
									"key": "to",
									"value": "BTC"
								},
								{
									"key": "amount",
									"value": "5000"
								}
							]
						},
						"description": "Requisito 4: Cota via CoinGecko com 1.5% de taxa"
					}
				},
				{
					"name": "Executar Swap",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"from\": \"BRL\",\n    \"to\": \"BTC\",\n    \"amount\": 5000\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/wallet/swap",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"wallet",
								"swap"
							]
						},
						"description": "Executa a troca. Gera 3 registros no Ledger (OUT, FEE, IN)"
					}
				}
			]
		},
		{
			"name": "4. Saque & Extrato",
			"item": [
				{
					"name": "Solicitar Saque (Withdrawal)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"token\": \"BRL\",\n    \"amount\": 500\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/wallet/withdraw",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"wallet",
								"withdraw"
							]
						},
						"description": "Requisito 5: Simula um saque e debita o saldo."
					}
				},
				{
					"name": "Ver Extrato (Ledger)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/wallet/statement?page=1&limit=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"wallet",
								"statement"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "10"
								}
							]
						},
						"description": "Requisito 6: Lista todas as movimentações de forma paginada e auditável."
					}
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "userId",
			"value": "",
			"type": "string"
		}
	]
}