// Configuração do Prisma Client e conexão com o banco de dados principal
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Gerencia os dados de autenticação e a identidade dos usuários na plataforma
model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  password           String
  hashedRefreshToken String?
  createdAt          DateTime @default(now())
  
  wallet             Wallet?
}

// Representa a carteira do usuário, agrupando todos os seus ativos e histórico de transações
model Wallet {
  id         String            @id @default(uuid())
  userId     String            @unique
  createdAt  DateTime          @default(now())
  
  user       User              @relation(fields: [userId], references: [id])
  assets     WalletAsset[]
  statements WalletStatement[]
}

// Armazena o saldo atualizado de cada token específico dentro de uma carteira
model WalletAsset {
  id       String  @id @default(uuid())
  walletId String
  token    String
  balance  Decimal @default(0) @db.Decimal(20, 8)
  
  wallet   Wallet  @relation(fields: [walletId], references: [id])

  @@unique([walletId, token])
}

// Registro imutável (ledger) de todas as movimentações financeiras para auditoria e histórico
model WalletStatement {
  id            String   @id @default(uuid())
  walletId      String
  type          String
  token         String
  amount        Decimal  @db.Decimal(20, 8)
  balanceBefore Decimal  @db.Decimal(20, 8)
  balanceAfter  Decimal  @db.Decimal(20, 8)
  createdAt     DateTime @default(now())
  
  wallet        Wallet   @relation(fields: [walletId], references: [id])
}

// Registra requisições para garantir que operações sensíveis não sejam processadas em duplicidade
model IdempotencyLog {
  key            String   @id
  method         String
  requestPayload String?
  responseStatus Int
  createdAt      DateTime @default(now())
}