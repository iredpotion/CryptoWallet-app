{
	"info": {
		"_postman_id": "crypto-wallet-v1-updated",
		"name": "Crypto Wallet API (Dia 1)",
		"description": "Collection para testar Auth e Wallet da crypto wallet. Inclui automação de token.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "1. Registrar Usuário",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"dev@dev.com\",\n    \"password\": \"senha123456\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"register"
							]
						},
						"description": "Cria usuário e carteira automaticamente."
					},
					"response": []
				},
				{
					"name": "2. Login (Auto-Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Verifica se o login foi sucesso",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Pega o token da resposta",
									"var jsonData = pm.response.json();",
									"",
									"if (jsonData.access_token) {",
									"    // Salva na variável de coleção 'token'",
									"    pm.collectionVariables.set(\"token\", jsonData.access_token);",
									"    console.log(\"Token salvo automaticamente: \" + jsonData.access_token);",
									"} else {",
									"    console.log(\"Token não encontrado na resposta\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"dev@dev.com\",\n    \"password\": \"senha123456\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Faz login e salva o JWT automaticamente para as próximas requisições."
					},
					"response": []
				}
			]
		},
		{
			"name": "Wallet",
			"item": [
				{
					"name": "3. Minha Carteira",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/wallet",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"wallet"
							]
						},
						"description": "Usa o token salvo para buscar a carteira do usuário logado (Herda Auth da coleção)."
					},
					"response": []
				},
				{
					"name": "4. Listar Todas (Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/wallet/all",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"wallet",
								"all"
							]
						},
						"description": "Rota de debug para ver todas as carteiras no banco."
					},
					"response": []
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	]
}