{
	"info": {
		"_postman_id": "crypto-wallet-v1-day3-fix",
		"name": "Crypto Wallet API (Dia 3 - Final)",
		"description": "Collection completa com Auth, Wallet, Webhook e Swap (Corrigido).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "1. Registrar Usuário",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"investor@nexus.com\",\n    \"password\": \"senha123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "2. Login (Auto-Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access_token) {",
									"    pm.collectionVariables.set(\"token\", jsonData.access_token);",
									"    console.log(\"Token salvo: \" + jsonData.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"investor@nexus.com\",\n    \"password\": \"senha123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"login"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Wallet",
			"item": [
				{
					"name": "3. Minha Carteira",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.userId) {",
									"    pm.collectionVariables.set(\"userId\", jsonData.userId);",
									"} else if (jsonData.user && jsonData.user.id) {",
									"    pm.collectionVariables.set(\"userId\", jsonData.user.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/wallet",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"wallet"
							]
						}
					},
					"response": []
				},
				{
					"name": "4. Depositar (Webhook)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"userId\": \"{{userId}}\",\n    \"token\": \"BRL\",\n    \"amount\": 10000,\n    \"idempotencyKey\": \"{{$guid}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/webhooks/deposit",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"webhooks",
								"deposit"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Swap (Dia 3)",
			"item": [
				{
					"name": "5. Cotar BRL -> BTC",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/wallet/swap/quote?from=BRL&to=BTC&amount=5000",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"wallet",
								"swap",
								"quote"
							],
							"query": [
								{
									"key": "from",
									"value": "BRL"
								},
								{
									"key": "to",
									"value": "BTC"
								},
								{
									"key": "amount",
									"value": "5000"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "6. Executar Swap",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"from\": \"BRL\",\n    \"to\": \"BTC\",\n    \"amount\": 5000\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/wallet/swap",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"wallet",
								"swap"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "userId",
			"value": "",
			"type": "string"
		}
	]
}