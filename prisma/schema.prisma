// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Lembre de hashear isso!
  createdAt DateTime @default(now())
  
  // Relacionamentos
  wallet    Wallet?
}

// Requisito: Carteira suporta BRL, BTC, ETH [cite: 24]
model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  
  // Saldos atuais (para leitura rápida) [cite: 25]
  balances  Balance[] 
  
  // Histórico auditável 
  transactions Transaction[]
}

model Balance {
  id        String   @id @default(uuid())
  walletId  String
  token     String   // BRL, BTC, ETH
  amount    Decimal  @default(0) // Use Decimal para dinheiro, nunca Float!
  
  wallet    Wallet   @relation(fields: [walletId], references: [id])

  @@unique([walletId, token]) // Um saldo por token por carteira
}

model Transaction {
  id        String   @id @default(uuid())
  walletId  String
  type      TransactionType // Enum abaixo
  token     String
  amount    Decimal
  
  // Requisito: saldo anterior e novo no registro [cite: 56]
  previousBalance Decimal
  newBalance      Decimal
  
  timestamp DateTime @default(now())
  
  wallet    Wallet   @relation(fields: [walletId], references: [id])
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  SWAP_IN
  SWAP_OUT
  SWAP_FEE
}